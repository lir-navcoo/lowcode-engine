# dependencies
node_modules/
.yarn/
.pnp.*

# npm auth token — never commit, never share in chat
.npmrc
npmrc.local

# build output
packages/*/lib/
packages/*/es/
packages/*/dist/
packages/*/build/
examples/demo/dist/
examples/demo/.vite/

# prevent stray .js/.d.ts in src/ (caused by cross-package tsc with wrong rootDir)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor
.DS_Store
**/.DS_Store
.vscode/
.idea/

# env
.env
.env.local

# lerna
lerna-debug.log
