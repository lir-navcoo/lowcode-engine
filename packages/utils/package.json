{
  "name": "@monbolc/lowcode-utils",
  "version": "2.1.0",
  "description": "Pure utility functions and type guards for SapuLowcodeEngine (L1)",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:es": "tsc -p tsconfig.esm.json && node ../../scripts/add-js-extensions.mjs es",
    "clean": "rimraf lib es"
  },
  "dependencies": {
    "@monbolc/lowcode-types": "^2.1.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:monbolc/sapu-lowcode-engine.git",
    "directory": "packages/utils"
  },
  "keywords": [
    "lowcode",
    "engine",
    "utils"
  ],
  "gitHead": "f2df4cee4b702fc980b0efaadf0b5a7b385c5af0"
}
