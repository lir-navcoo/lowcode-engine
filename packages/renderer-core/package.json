{
  "name": "@monbolc/lowcode-renderer-core",
  "version": "2.1.6",
  "description": "Framework-agnostic renderer core with React-runtime adapter for SapuLowcodeEngine (L2)",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "es",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:es",
    "build:es": "tsc -p tsconfig.esm.json && node ../../scripts/add-js-extensions.mjs es",
    "clean": "rimraf lib es",
    "build:cjs": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@monbolc/lowcode-types": "^2.1.5",
    "@monbolc/lowcode-utils": "^2.1.5"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:lir-navcoo/lowcode-engine.git",
    "directory": "packages/renderer-core"
  },
  "keywords": [
    "lowcode",
    "engine",
    "renderer",
    "react"
  ],
  "gitHead": "f2df4cee4b702fc980b0efaadf0b5a7b385c5af0"
}
