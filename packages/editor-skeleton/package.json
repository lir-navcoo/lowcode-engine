{
  "name": "@monbolc/lowcode-editor-skeleton",
  "version": "2.1.0",
  "description": "3-pane editor layout (outline / canvas / settings) for SapuLowcodeEngine (L4)",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./styles.css": "./lib/styles.css"
  },
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "build": "yarn build:css && tsc -p tsconfig.json",
    "build:css": "tailwindcss -i src/styles.css -o lib/styles.css --minify",
    "build:es": "tsc -p tsconfig.esm.json && node ../../scripts/add-js-extensions.mjs es",
    "clean": "rimraf lib es"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0",
    "@monbolc/lowcode-designer": "^2.1.0",
    "@monbolc/lowcode-plugin-outline-pane": "^2.1.0",
    "@monbolc/lowcode-plugin-setters": "^2.1.0",
    "@monbolc/lowcode-react-renderer": "^2.1.0",
    "@monbolc/lowcode-renderer-core": "^2.1.0",
    "@monbolc/lowcode-types": "^2.1.0",
    "@monbolc/lowcode-utils": "^2.1.0",
    "react-resizable-panels": "^2.1.7"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^5.0.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:monbolc/sapu-lowcode-engine.git",
    "directory": "packages/editor-skeleton"
  },
  "keywords": [
    "lowcode",
    "engine",
    "editor",
    "skeleton",
    "ui",
    "tailwind"
  ],
  "gitHead": "f2df4cee4b702fc980b0efaadf0b5a7b385c5af0"
}
