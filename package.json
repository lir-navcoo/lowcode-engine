{
  "name": "sapu-lowcode-engine",
  "version": "2.0.0",
  "private": true,
  "description": "SapuLowcodeEngine - enterprise-class low-code engine (sapu = monbolc open-source brand)",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "build": "lerna run build --stream",
    "clean": "rimraf ./packages/*/lib ./packages/*/es ./packages/*/dist",
    "demo": "cd examples/demo && vite",
    "demo:build": "cd examples/demo && vite build",
    "demo:preview": "cd examples/demo && vite preview",
    "lint": "eslint packages/*/src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "node scripts/typecheck.mjs",
    "pub:patch": "lerna publish patch --yes --force-publish --no-changelog",
    "pub:minor": "lerna publish minor --yes --force-publish --no-changelog",
    "pub:major": "lerna publish major --yes --force-publish --no-changelog"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "happy-dom": "^15.0.0",
    "lerna": "^8.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "react-arborist": "^3.9.0"
  }
}
