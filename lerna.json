{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "2.1.0",
  "npmClient": "yarn",
  "packages": [
    "packages/*"
  ],
  "command": {
    "version": {
      "allowBranch": [
        "main",
        "release/*"
      ]
    },
    "publish": {
      "npmClient": "npm",
      "verifyRegistry": false,
      "verifyAccess": false,
      "ignoreChanges": [
        "**/*.md",
        "**/test/**"
      ],
      "message": "chore(release): publish %v",
      "conventionalCommits": true
    }
  }
}